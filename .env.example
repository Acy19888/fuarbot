# ============================================
# FuarBot – Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Claude API (for AI business card OCR) ---
# Get yours at: https://console.anthropic.com/
# This goes into Vercel as a SERVER-SIDE env var (no VITE_ prefix!)
CLAUDE_API_KEY=

# --- Firebase (for database) ---
# Get from: Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_ID=
VITE_FIREBASE_APP_ID=
