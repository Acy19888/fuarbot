# ============================================
# FuarBot – Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Claude API (for AI business card OCR) ---
# Get yours at: https://console.anthropic.com/
CLAUDE_API_KEY=

# --- Firebase (for database) ---
# Get from: Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_ID=
VITE_FIREBASE_APP_ID=

# --- Email (SMTP via Google Workspace) ---
# SMTP_USER = your Google Workspace email (e.g. info@yourcompany.com)
# SMTP_PASS = App Password from https://myaccount.google.com/apppasswords
# SMTP_FROM = sender email (usually same as SMTP_USER)
# COMPANY_NAME = shown in email header and signature
# CATALOG_URL = link to your product catalog
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
COMPANY_NAME=
CATALOG_URL=
